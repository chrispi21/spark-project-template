{
  "name": "spark-cluster",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    },
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17"
    }
  },

  "forwardPorts": [8080, 8888, 4040],

  "postCreateCommand": "bash scripts/start-cluster.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-toolsai.jupyter",
        "ms-python.python"
      ]
    }
  }
}
