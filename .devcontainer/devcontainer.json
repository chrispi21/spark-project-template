{
  "name": "spark-project-template",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    },
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17"
    }
  },

  "runArgs": ["--dns=8.8.8.8", "--dns=1.1.1.1"],

  "forwardPorts": [8080, 8888, 4040],

  "postCreateCommand": "bash scripts/start-services.sh --build",
  "postStartCommand": "bash scripts/start-services.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-toolsai.jupyter",
        "ms-python.python"
      ]
    }
  }
}
